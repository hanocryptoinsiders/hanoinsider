# ─────────────────────────────────────────────────────────────────────────────
# Hano Insiders — environment variables
# Copy to .env.local for local dev. Set the same values in Vercel (app) and
# Railway (crypto watcher) for production.
# ─────────────────────────────────────────────────────────────────────────────

# Core
NEXT_PUBLIC_SITE_URL=https://hanoinsiders.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (card checkout)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_REGULAR_MONTHLY_PRICE_ID=
STRIPE_EARLY_BIRD_PRICE_ID=
STRIPE_YEARLY_PRICE_ID=
STRIPE_QUARTERLY_PRICE_ID=
STRIPE_REFERRAL_10_OFF_COUPON_ID=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM="Hano Insiders <hi@hanoinsiders.com>"
EMAIL_REPLY_TO=hi@hanoinsiders.com

# Market data
COINMARKETCAP_API_KEY=

# Cron / worker auth (used by /api/cron/* and the Railway watcher)
CRON_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Automatic crypto payments — USDC / USDT (BEP20) on BNB Smart Chain
# Buyers can pay with EITHER USDC or USDT on BSC; bridges (e.g. relay.link from
# Solana) deliver USDC and are matched automatically by amount — no tx hash
# needed (a Solana hash is fine, it's just ignored for matching).
# ─────────────────────────────────────────────────────────────────────────────

# Toggle the whole crypto method off by setting this to "false".
CRYPTO_PAYMENTS_ENABLED=true

# On-chain reader. Alchemy's FREE tier covers BSC; Etherscan's free tier does NOT.
# Create a free app for "BNB Smart Chain Mainnet" at https://dashboard.alchemy.com
# and paste just the API key. (REQUIRED for verification to work.)
ALCHEMY_API_KEY=
# Optional fallback (Etherscan V2 — works for ETH mainnet, not free-tier BSC):
ETHERSCAN_API_KEY=

# Receiving wallet (EVM 0x address). Defaults in code to the address below if unset.
CRYPTO_RECEIVING_WALLET=0x1b9b412726fb86eef215eb4ec9cef58a095fdc38

# Accepted tokens default to BOTH USDC and USDT on BSC (chain 56, 18 decimals).
# Set CRYPTO_CURRENCY / CRYPTO_TOKEN_CONTRACT only to add/display a custom token.
# CRYPTO_CURRENCY=USDC
# CRYPTO_TOKEN_CONTRACT=0x8AC76a51cc950d9822D68b83fE1Ad97B32Cd580d
# CRYPTO_TOKEN_DECIMALS=18
# CRYPTO_CHAIN_ID=56

# Payment window (minutes), confirmations, and how much under the exact amount
# we still accept (covers bridge/exchange fees). Overpayment is always accepted.
CRYPTO_PAYMENT_WINDOW_MINUTES=10
CRYPTO_MIN_CONFIRMATIONS=3
CRYPTO_AMOUNT_TOLERANCE_USD=0.5

# TEST MODE: charge a flat amount for crypto regardless of plan price.
# Set to e.g. 0.1 to test the full flow cheaply. Remove for production
# (production then charges the real plan price: $79 regular / $49 early bird).
CRYPTO_PRICE_USD_OVERRIDE=0.1

# ─────────────────────────────────────────────────────────────────────────────
# Railway worker only (worker/crypto-poller.mjs)
# ─────────────────────────────────────────────────────────────────────────────
# APP_URL=https://hanoinsiders.com
# POLL_INTERVAL_MS=20000
